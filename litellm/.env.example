# === LiteLLM proxy — variabili d'ambiente ===
# Copia in .env e compila i valori reali (non committare .env nel VCS)

# Chiave master per autenticare Spring AI → LiteLLM
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# Provider API keys (inserisci solo quelle che usi)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
CEREBRAS_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_API_KEY=
